---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Collections',
    links: [
      { label: 'Facial Care', href: '/collections/facial-care' },
      { label: 'Body Rituals', href: '/collections/body-rituals' },
      { label: 'Hair Care', href: '/collections/hair-care' },
      { label: 'Home Fragrance', href: '/collections/home-fragrance' },
    ],
  },
  {
    heading: 'The House',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Journal', href: '/journal' },
      { label: 'Ingredients', href: '/about#ingredients' },
      { label: 'Sustainability', href: '/about#sustainability' },
    ],
  },
  {
    heading: 'Care',
    links: [
      { label: 'Shipping & Returns', href: '#' },
      { label: 'Contact', href: '#' },
      { label: 'FAQ', href: '#' },
      { label: 'Stockists', href: '#' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="footer-top container">
    <div class="footer-brand">
      <a href="/" class="footer-logo">Maison Clair</a>
      <p class="footer-tagline">
        A considered approach to skin.<br />
        Formulated with rare botanicals.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      {columns.map((col) => (
        <div class="footer-col">
          <h3 class="footer-col-heading t-eyebrow">{col.heading}</h3>
          <ul class="footer-col-links">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="footer-link link-underline">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="footer-bottom container">
    <p class="footer-legal">
      &copy; {year} Maison Clair. All rights reserved.
    </p>
    <div class="footer-legal-links">
      <a href="#" class="footer-link link-underline">Privacy Policy</a>
      <a href="#" class="footer-link link-underline">Terms of Use</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    color: var(--color-accent-light);
    margin-top: var(--space-20);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-12);
    padding-top: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border-dark);
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-bg);
    display: inline-block;
    margin-bottom: var(--space-3);
    transition: color var(--transition-base);
  }

  .footer-logo:hover {
    color: var(--color-accent-light);
  }

  .footer-tagline {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-ink-faint);
    max-width: 24ch;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .footer-col-heading {
    color: var(--color-ink-faint);
    margin-bottom: var(--space-3);
  }

  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-accent-light);
    transition: color var(--transition-base);
  }

  .footer-link:hover {
    color: var(--color-bg);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-4);
    padding-bottom: var(--space-6);
    gap: var(--space-4);
  }

  .footer-legal {
    font-size: var(--text-xs);
    color: var(--color-ink-faint);
    letter-spacing: 0.04em;
    max-width: none;
  }

  .footer-legal-links {
    display: flex;
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer-nav {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
